#!/bin/bash
set -euo pipefail

mkdir -p "${TRIM_PKGHOME}/mihomo"
mkdir -p "${TRIM_PKGVAR}"

# Read wizard values
CONFIG_PROFILE="${wizard_config_profile:-OneSmart}"
SECRET="${wizard_secret:-yyds666}"
PROVIDER_URL_1="${wizard_provider_url_1:-}"
PROVIDER_URL_2="${wizard_provider_url_2:-}"
PROVIDER_URL_3="${wizard_provider_url_3:-}"

# 确定配置目录（优先使用 data-share 路径）
CONFIG_DIR="${TRIM_PKGHOME}/mihomo"
if [ -n "${TRIM_DATA_SHARE_PATHS:-}" ]; then
    SHARE_DIR=$(echo "${TRIM_DATA_SHARE_PATHS}" | cut -d: -f1)
    [ -n "${SHARE_DIR}" ] && CONFIG_DIR="${SHARE_DIR}"
fi
mkdir -p "${CONFIG_DIR}"

# 记录配置路径（用于重新安装时恢复旧配置）
echo "${CONFIG_DIR}" > "${TRIM_PKGVAR}/.config_dir"
CONFIG_FILE="${CONFIG_DIR}/config.yaml"

# ---- 关键：检查配置是否已存在（防止重装覆盖） ----
if [ -f "${CONFIG_FILE}" ]; then
    echo "配置文件已存在，跳过创建: ${CONFIG_FILE}"
    exit 0
fi

# ---- 尝试从旧路径恢复配置（重装场景） ----
if [ -f "${TRIM_PKGVAR}/.config_dir_prev" ]; then
    PREV_DIR=$(cat "${TRIM_PKGVAR}/.config_dir_prev" 2>/dev/null)
    if [ -n "${PREV_DIR}" ] && [ -f "${PREV_DIR}/config.yaml" ]; then
        echo "从旧路径恢复配置: ${PREV_DIR}/config.yaml"
        cp "${PREV_DIR}/config.yaml" "${CONFIG_FILE}"
        exit 0
    fi
fi

# ---- 全新安装：从模板创建 ----
TEMPLATE="${TRIM_APPDEST}/server/config/${CONFIG_PROFILE}.yaml"
if [ -f "${TEMPLATE}" ]; then
    cp "${TEMPLATE}" "${CONFIG_FILE}"
    sed -i "s/MB_SECRET/${SECRET}/g" "${CONFIG_FILE}"

    if [ -n "${PROVIDER_URL_1}" ]; then
        sed -i "s|AIRPORT_URL1|${PROVIDER_URL_1}|g" "${CONFIG_FILE}"
    else
        sed -i "s|AIRPORT_URL1|https://example.com/subscribe?token=YOUR_TOKEN_HERE|g" "${CONFIG_FILE}"
    fi

    if grep -q "AIRPORT_URL2" "${CONFIG_FILE}" 2>/dev/null; then
        URL2="${PROVIDER_URL_2:-${PROVIDER_URL_1:-}}"
        if [ -n "${URL2}" ]; then
            sed -i "s|AIRPORT_URL2|${URL2}|g" "${CONFIG_FILE}"
        else
            sed -i "s|AIRPORT_URL2|https://example.com/subscribe?token=YOUR_TOKEN_HERE|g" "${CONFIG_FILE}"
        fi
    fi

    if grep -q "AIRPORT_URL3" "${CONFIG_FILE}" 2>/dev/null; then
        if [ -n "${PROVIDER_URL_3}" ]; then
            sed -i "s|AIRPORT_URL3|${PROVIDER_URL_3}|g" "${CONFIG_FILE}"
        else
            sed -i "s|AIRPORT_URL3|https://example.com/subscribe?token=YOUR_TOKEN_HERE|g" "${CONFIG_FILE}"
        fi
    fi
fi

exit 0
