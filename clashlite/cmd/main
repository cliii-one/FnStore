#!/bin/bash
set -euo pipefail

MIHOMO_BIN="${TRIM_PKGHOME}/mihomo/mihomo"
MIHOMO_DIR="${TRIM_PKGHOME}/mihomo"
MIHOMO_CONFIG="${MIHOMO_DIR}/config.yaml"
MIHOMO_SOCKET="${TRIM_APPDEST}/mihomo.sock"
PID_FILE="${TRIM_PKGVAR}/mihomo.pid"
PROXY_PID_FILE="${TRIM_PKGVAR}/clashlite.pid"
LOG_FILE="${TRIM_PKGVAR}/info.log"
GATEWAY_PROXY_BIN="${TRIM_APPDEST}/server/clashlite"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

if [ -n "${TRIM_DATA_SHARE_PATHS:-}" ]; then
    SHARE_DIR=$(echo "${TRIM_DATA_SHARE_PATHS}" | cut -d: -f1)
    if [ -f "${SHARE_DIR}/config.yaml" ]; then
        MIHOMO_CONFIG="${SHARE_DIR}/config.yaml"
    fi
fi

ensure_config() {
    if [ ! -f "${MIHOMO_CONFIG}" ]; then
        local template="${TRIM_APPDEST}/server/config/OneSmart.yaml"
        if [ -f "${template}" ]; then
            mkdir -p "$(dirname "${MIHOMO_CONFIG}")"
            cp "${template}" "${MIHOMO_CONFIG}"
            sed -i "s/MB_SECRET/yyds666/g" "${MIHOMO_CONFIG}"
            sed -i "s|AIRPORT_URL1|https://example.com/subscribe?token=YOUR_TOKEN_HERE|g" "${MIHOMO_CONFIG}"
            log_msg "Config created from template: ${MIHOMO_CONFIG}"
        fi
    fi
    if [ -f "${MIHOMO_CONFIG}" ]; then
        if grep -q "MIHOMO_UNIX_SOCKET" "${MIHOMO_CONFIG}"; then
            sed -i "s|MIHOMO_UNIX_SOCKET|${MIHOMO_SOCKET}|g" "${MIHOMO_CONFIG}"
            log_msg "已设置 external-controller-unix: ${MIHOMO_SOCKET}"
        fi
        if ! grep -q "external-controller-unix" "${MIHOMO_CONFIG}"; then
            sed -i "/^external-controller:/a external-controller-unix: ${MIHOMO_SOCKET}" "${MIHOMO_CONFIG}"
            log_msg "已追加 external-controller-unix: ${MIHOMO_SOCKET}"
        fi
        if grep -q "^external-controller:" "${MIHOMO_CONFIG}"; then
            sed -i "/^external-controller:/d" "${MIHOMO_CONFIG}"
            log_msg "已删除旧的 external-controller（TCP 端口），改用 Unix Socket"
        fi
    fi
}

copy_bundled() {
    local bundled_dir="${TRIM_APPDEST}/server/data/mihomo"
    if [ -d "${bundled_dir}" ]; then
        mkdir -p "${MIHOMO_DIR}"
        cp -f "${bundled_dir}/mihomo" "${MIHOMO_DIR}/mihomo" 2>/dev/null && chmod +x "${MIHOMO_DIR}/mihomo"
        for f in Model.bin geoip.metadb geosite.dat ASN.mmdb; do
            if [ -f "${bundled_dir}/${f}" ] && [ ! -f "${MIHOMO_DIR}/${f}" ]; then
                cp "${bundled_dir}/${f}" "${MIHOMO_DIR}/${f}"
            fi
        done
    fi
}

copy_ui() {
    local src="${TRIM_APPDEST}/server/public"
    local dst="${MIHOMO_DIR}/ui"
    if [ -d "${src}" ] && [ ! -d "${dst}" ]; then
        cp -r "${src}" "${dst}"
        log_msg "metacubexd copied to ${dst}"
    fi
}

start_mihomo() {
    if check_mihomo_status; then
        return 0
    fi

    copy_bundled
    copy_ui
    ensure_config

    if [ ! -x "${MIHOMO_BIN}" ]; then
        log_msg "ERROR: mihomo binary not found at ${MIHOMO_BIN}"
        echo "【启动异常】未找到 mihomo 核心程序文件。" > "${TRIM_TEMP_LOGFILE}"
        echo "请尝试在飞牛应用中心卸载后重新安装此应用。" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi

    rm -f "${MIHOMO_SOCKET}"
    log_msg "Starting mihomo (with external-controller-unix: ${MIHOMO_SOCKET}) ..."

    local args=(-d "${MIHOMO_DIR}")
    if [ "${MIHOMO_CONFIG}" != "${MIHOMO_DIR}/config.yaml" ]; then
        args+=(-f "${MIHOMO_CONFIG}")
    fi

    "${MIHOMO_BIN}" "${args[@]}" >> "${LOG_FILE}" 2>&1 &
    local pid=$!
    printf "%s" "${pid}" > "${PID_FILE}"
    log_msg "mihomo started with PID ${pid}"

    local count=0
    while [ ${count} -lt 15 ]; do
        if [ -S "${MIHOMO_SOCKET}" ]; then
            log_msg "mihomo Unix Socket 已就绪: ${MIHOMO_SOCKET}"
            return 0
        fi
        sleep 1
        count=$((count + 1))
    done
    log_msg "WARNING: mihomo Unix Socket 未在 15 秒内就绪，继续启动网关代理"
    return 0
}

start_gateway_proxy() {
    if check_proxy_status; then
        return 0
    fi

    if [ ! -x "${GATEWAY_PROXY_BIN}" ]; then
        log_msg "ERROR: clashlite binary not found at ${GATEWAY_PROXY_BIN}"
        echo "【启动异常】未找到网关反向代理程序。" > "${TRIM_TEMP_LOGFILE}"
        echo "请尝试在飞牛应用中心卸载后重新安装此应用。" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi

    log_msg "Starting clashlite gateway-proxy ..."

    "${GATEWAY_PROXY_BIN}" >> "${LOG_FILE}" 2>&1 &
    local pid=$!
    printf "%s" "${pid}" > "${PROXY_PID_FILE}"
    log_msg "clashlite started with PID ${pid}"

    local socket_path="${TRIM_APPDEST}/clashlite.sock"
    local count=0
    while [ ${count} -lt 5 ]; do
        if [ -S "${socket_path}" ]; then
            log_msg "clashlite Unix Socket 已就绪: ${socket_path}"
            return 0
        fi
        sleep 1
        count=$((count + 1))
    done
    log_msg "WARNING: clashlite Socket 未在 5 秒内就绪"
    return 0
}

stop_mihomo() {
    log_msg "Stopping mihomo ..."

    if [ -r "${PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            log_msg "Sending TERM to PID:${pid}"
            kill -TERM "${pid}" 2>/dev/null || true

            local count=0
            while kill -0 "${pid}" 2>/dev/null && [ ${count} -lt 10 ]; do
                sleep 1
                count=$((count + 1))
            done

            if kill -0 "${pid}" 2>/dev/null; then
                log_msg "Sending KILL to PID:${pid}"
                kill -KILL "${pid}" 2>/dev/null || true
                sleep 1
            fi
        fi
        rm -f "${PID_FILE}"
    fi

    local mihomo_pid
    mihomo_pid=$(pgrep -f "mihomo -d ${MIHOMO_DIR}" 2>/dev/null) || true
    if [ -n "${mihomo_pid}" ]; then
        log_msg "Killing orphan mihomo: ${mihomo_pid}"
        kill -TERM ${mihomo_pid} 2>/dev/null || true
        sleep 2
        mihomo_pid=$(pgrep -f "mihomo -d ${MIHOMO_DIR}" 2>/dev/null) || true
        if [ -n "${mihomo_pid}" ]; then
            kill -KILL ${mihomo_pid} 2>/dev/null || true
        fi
    fi
    rm -f "${MIHOMO_SOCKET}"
    return 0
}

stop_gateway_proxy() {
    log_msg "Stopping clashlite ..."

    if [ -r "${PROXY_PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PROXY_PID_FILE}" | tr -d '[:space:]')

        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            log_msg "Sending TERM to clashlite PID:${pid}"
            kill -TERM "${pid}" 2>/dev/null || true

            local count=0
            while kill -0 "${pid}" 2>/dev/null && [ ${count} -lt 5 ]; do
                sleep 1
                count=$((count + 1))
            done

            if kill -0 "${pid}" 2>/dev/null; then
                kill -KILL "${pid}" 2>/dev/null || true
            fi
        fi
        rm -f "${PROXY_PID_FILE}"
    fi

    local proxy_pid
    proxy_pid=$(pgrep -f "${GATEWAY_PROXY_BIN}" 2>/dev/null) || true
    if [ -n "${proxy_pid}" ]; then
        kill -TERM ${proxy_pid} 2>/dev/null || true
        sleep 1
    fi

    local socket_path="${TRIM_APPDEST}/clashlite.sock"
    rm -f "${socket_path}"
    return 0
}

check_mihomo_status() {
    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi
    return 1
}

check_proxy_status() {
    if [ -f "${PROXY_PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PROXY_PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            return 0
        else
            rm -f "${PROXY_PID_FILE}"
        fi
    fi
    return 1
}

case "${1:-}" in
start)
    mkdir -p "${TRIM_PKGVAR}"
    start_mihomo
    start_gateway_proxy
    ;;
stop)
    stop_gateway_proxy
    stop_mihomo
    ;;
status)
    if check_mihomo_status && check_proxy_status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    echo "Usage: $0 {start|stop|status}" >&2
    exit 1
    ;;
esac
