#!/bin/bash
set -euo pipefail

MIHOMO_DIR="${TRIM_PKGHOME}/mihomo"
MIHOMO_BIN="${MIHOMO_DIR}/mihomo"
MIHOMO_CONFIG="${MIHOMO_DIR}/config.yaml"
MIHOMO_SOCKET="${TRIM_APPDEST}/mihomo.sock"
CLASHLITE_SOCK="${TRIM_APPDEST}/clashlite.sock"
PROXY_BIN="${TRIM_APPDEST}/server/clashlite"
MIHOMO_PID="${TRIM_PKGVAR}/mihomo.pid"
PROXY_PID="${TRIM_PKGVAR}/clashlite.pid"
LOG_FILE="${TRIM_PKGVAR}/info.log"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

# data-share 配置优先
if [ -n "${TRIM_DATA_SHARE_PATHS:-}" ]; then
    SHARE_DIR="${TRIM_DATA_SHARE_PATHS%%:*}"
    [ -f "${SHARE_DIR}/config.yaml" ] && MIHOMO_CONFIG="${SHARE_DIR}/config.yaml"
fi

ensure_config() {
    [ ! -f "${MIHOMO_CONFIG}" ] || return 0

    local tmpl="${TRIM_APPDEST}/server/config/OneSmart.yaml"
    [ ! -f "${tmpl}" ] && return 0

    mkdir -p "$(dirname "${MIHOMO_CONFIG}")"
    cp "${tmpl}" "${MIHOMO_CONFIG}"
    sed -i "s/MB_SECRET/yyds666/g" "${MIHOMO_CONFIG}"
    sed -i "s|AIRPORT_URL1|https://example.com/subscribe?token=YOUR_TOKEN_HERE|g" "${MIHOMO_CONFIG}"
    log_msg "Config created from template"
}

copy_bundled() {
    local src="${TRIM_APPDEST}/server/data/mihomo"
    [ ! -d "${src}" ] && return 0

    mkdir -p "${MIHOMO_DIR}"
    cp -f "${src}/mihomo" "${MIHOMO_BIN}" && chmod +x "${MIHOMO_BIN}"

    for f in Model.bin geoip.metadb geosite.dat ASN.mmdb; do
        [ -f "${src}/${f}" ] && [ ! -f "${MIHOMO_DIR}/${f}" ] && cp "${src}/${f}" "${MIHOMO_DIR}/${f}"
    done
}

copy_ui() {
    local src="${TRIM_APPDEST}/server/public"
    local dst="${MIHOMO_DIR}/ui"
    [ ! -d "${src}" ] || [ -d "${dst}" ] && return 0
    cp -r "${src}" "${dst}"
}

start_mihomo() {
    check_mihomo_status && return 0

    copy_bundled
    copy_ui
    ensure_config

    if [ ! -x "${MIHOMO_BIN}" ]; then
        echo "【启动异常】未找到 mihomo 核心程序文件。" > "${TRIM_TEMP_LOGFILE}"
        echo "请尝试在飞牛应用中心卸载后重新安装此应用。" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi

    rm -f "${MIHOMO_SOCKET}"
    log_msg "Starting mihomo ..."

    local args=(-d "${MIHOMO_DIR}")
    [ "${MIHOMO_CONFIG}" != "${MIHOMO_DIR}/config.yaml" ] && args+=(-f "${MIHOMO_CONFIG}")

    "${MIHOMO_BIN}" "${args[@]}" >> "${LOG_FILE}" 2>&1 &
    echo $! > "${MIHOMO_PID}"
    log_msg "mihomo started with PID $(cat "${MIHOMO_PID}")"

    for i in $(seq 1 15); do
        [ -S "${MIHOMO_SOCKET}" ] && { log_msg "mihomo socket ready"; return 0; }
        sleep 1
    done

    log_msg "WARNING: mihomo socket not ready in 15s"
    return 0
}

start_proxy() {
    check_proxy_status && return 0

    if [ ! -x "${PROXY_BIN}" ]; then
        echo "【启动异常】未找到 clashlite 网关程序。" > "${TRIM_TEMP_LOGFILE}"
        echo "请尝试在飞牛应用中心卸载后重新安装此应用。" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi

    log_msg "Starting clashlite ..."
    "${PROXY_BIN}" >> "${LOG_FILE}" 2>&1 &
    echo $! > "${PROXY_PID}"
    log_msg "clashlite started with PID $(cat "${PROXY_PID}")"

    for i in $(seq 1 5); do
        [ -S "${CLASHLITE_SOCK}" ] && { log_msg "clashlite socket ready"; return 0; }
        sleep 1
    done

    log_msg "WARNING: clashlite socket not ready in 5s"
    return 0
}

stop_mihomo() {
    log_msg "Stopping mihomo ..."

    if [ -f "${MIHOMO_PID}" ]; then
        local pid
        pid=$(cat "${MIHOMO_PID}" | tr -d '[:space:]')
        [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null && kill -TERM "${pid}" 2>/dev/null || true
        rm -f "${MIHOMO_PID}"
    fi

    sleep 2
    pkill -f "mihomo" 2>/dev/null || true
    rm -f "${MIHOMO_SOCKET}"
}

stop_proxy() {
    log_msg "Stopping clashlite ..."

    if [ -f "${PROXY_PID}" ]; then
        local pid
        pid=$(cat "${PROXY_PID}" | tr -d '[:space:]')
        [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null && kill -TERM "${pid}" 2>/dev/null || true
        rm -f "${PROXY_PID}"
    fi

    sleep 1
    pkill -f "${PROXY_BIN}" 2>/dev/null || true
    rm -f "${CLASHLITE_SOCK}"
}

check_mihomo_status() {
    [ -f "${MIHOMO_PID}" ] && kill -0 "$(cat "${MIHOMO_PID}" | tr -d '[:space:]')" 2>/dev/null && return 0
    rm -f "${MIHOMO_PID}"
    return 1
}

check_proxy_status() {
    [ -f "${PROXY_PID}" ] && kill -0 "$(cat "${PROXY_PID}" | tr -d '[:space:]')" 2>/dev/null && return 0
    rm -f "${PROXY_PID}"
    return 1
}

case "${1:-}" in
start)
    mkdir -p "${TRIM_PKGVAR}"
    start_mihomo
    start_proxy
    ;;
stop)
    stop_proxy
    stop_mihomo
    ;;
status)
    check_mihomo_status && check_proxy_status && exit 0 || exit 3
    ;;
*)
    echo "Usage: $0 {start|stop|status}" >&2
    exit 1
    ;;
esac
