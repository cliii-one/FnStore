#!/bin/bash
set -euo pipefail

# 读取向导选择（默认保留数据）
DATA_ACTION="${wizard_data_action:-keep}"

if [ "${DATA_ACTION}" = "delete" ]; then
    # 系统已自动删除 target、tmp、home、etc
    # 这里清理系统保留的目录：var 和 shares

    # 删除 var 目录（日志、PID 等运行时数据）
    rm -rf "${TRIM_PKGVAR}"

    # 删除 data-share 共享目录（配置文件）
    if [ -n "${TRIM_DATA_SHARE_PATHS:-}" ]; then
        SHARE_DIR=$(echo "${TRIM_DATA_SHARE_PATHS}" | cut -d: -f1)
        if [ -n "${SHARE_DIR}" ] && [ -d "${SHARE_DIR}" ]; then
            rm -rf "${SHARE_DIR}"
        fi
    fi
fi

exit 0
