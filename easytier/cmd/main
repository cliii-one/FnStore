#!/bin/bash
set -euo pipefail

EASYTIER_DIR="${TRIM_PKGHOME}/easytier"
CORE_PID_FILE="${TRIM_PKGVAR}/easytier-core.pid"
WEB_PID_FILE="${TRIM_PKGVAR}/easytier-web.pid"
LOG_FILE="${TRIM_PKGVAR}/info.log"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

# 从安装目录复制二进制到可写目录（已存在且可执行则跳过）
copy_bundled() {
    local bundled_dir="${TRIM_APPDEST}/server/data/easytier"
    [ ! -d "${bundled_dir}" ] && return 0
    mkdir -p "${EASYTIER_DIR}"
    for f in easytier-core easytier-web-embed easytier-cli; do
        [ -x "${EASYTIER_DIR}/${f}" ] && continue
        [ -f "${bundled_dir}/${f}" ] && cp -f "${bundled_dir}/${f}" "${EASYTIER_DIR}/${f}" && chmod +x "${EASYTIER_DIR}/${f}"
    done
}

# 等待进程启动，超时返回 1
wait_for_pid() {
    local pid=$1 timeout=${2:-5}
    local count=0
    while [ ${count} -lt ${timeout} ]; do
        kill -0 "${pid}" 2>/dev/null && return 0
        sleep 1
        count=$((count + 1))
    done
    return 1
}

# 通过 PID 文件停止进程，失败则用 pgrep 兜底
stop_by_pid_file() {
    local pid_file=$1 pattern=$2
    if [ -r "${pid_file}" ]; then
        local pid
        pid=$(head -n 1 "${pid_file}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            kill -TERM "${pid}" 2>/dev/null || true
            local count=0
            while kill -0 "${pid}" 2>/dev/null && [ ${count} -lt 10 ]; do
                sleep 1
                count=$((count + 1))
            done
            kill -0 "${pid}" 2>/dev/null && kill -KILL "${pid}" 2>/dev/null || true
        fi
        rm -f "${pid_file}"
        return 0
    fi
    # PID 文件不存在时用 pgrep 兜底
    local pids
    pids=$(pgrep -f "${pattern}" 2>/dev/null) || true
    [ -n "${pids}" ] && kill -TERM ${pids} 2>/dev/null || true
}

start_core() {
    check_core_status && return 0

    copy_bundled

    if [ ! -x "${EASYTIER_DIR}/easytier-core" ]; then
        echo "【启动异常】未找到 EasyTier 核心程序文件。" > "${TRIM_TEMP_LOGFILE}"
        echo "请尝试在飞牛应用中心卸载后重新安装此应用。" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi

    export ET_STATE_DIR="${TRIM_PKGVAR}"
    cd "${TRIM_PKGVAR}"
    "${EASYTIER_DIR}/easytier-core" -w "udp://127.0.0.1:22020/admin" >> "${LOG_FILE}" 2>&1 &
    printf "%s" "$!" > "${CORE_PID_FILE}"

    if ! wait_for_pid "$!" 10; then
        log_msg "WARNING: easytier-core may not have started properly"
    fi
}

start_web() {
    check_web_status && return 0

    if [ ! -x "${EASYTIER_DIR}/easytier-web-embed" ]; then
        log_msg "WARNING: easytier-web-embed not found, skipping web console"
        return 0
    fi

    export ET_STATE_DIR="${TRIM_PKGVAR}"
    export ET_WEB_DB="${TRIM_PKGVAR}/et.db"
    cd "${TRIM_PKGVAR}"
    "${EASYTIER_DIR}/easytier-web-embed" \
        --db "${TRIM_PKGVAR}/et.db" \
        --api-server-port 11211 \
        --config-server-port 22020 \
        --config-server-protocol udp \
        >> "${LOG_FILE}" 2>&1 &
    printf "%s" "$!" > "${WEB_PID_FILE}"

    if ! wait_for_pid "$!" 5; then
        log_msg "WARNING: easytier-web-embed may not have started properly"
    fi
}

check_core_status() {
    if [ -f "${CORE_PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${CORE_PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            return 0
        fi
        rm -f "${CORE_PID_FILE}"
    fi
    return 1
}

check_web_status() {
    if [ -f "${WEB_PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${WEB_PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            return 0
        fi
        rm -f "${WEB_PID_FILE}"
    fi
    return 1
}

case "${1:-}" in
start)
    mkdir -p "${TRIM_PKGVAR}"
    start_core
    start_web
    ;;
stop)
    stop_by_pid_file "${WEB_PID_FILE}" "easytier-web-embed"
    stop_by_pid_file "${CORE_PID_FILE}" "easytier-core"
    ;;
status)
    check_core_status && exit 0 || exit 3
    ;;
*)
    echo "Usage: $0 {start|stop|status}" >&2
    exit 1
    ;;
esac
