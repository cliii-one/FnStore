#!/bin/bash
set -euo pipefail

mkdir -p "${TRIM_PKGHOME}/easytier"
mkdir -p "${TRIM_PKGVAR}"

NETWORK_NAME="${wizard_network_name:-my-network}"
NETWORK_SECRET="${wizard_network_secret:-}"
VIRTUAL_IP="${wizard_virtual_ip:-10.144.144.1}"
PUBLIC_SERVER="${wizard_public_server:-tcp://easytier.public.com:11010}"
ENABLE_ENCRYPTION="${wizard_enable_encryption:-true}"
LATENCY_FIRST="${wizard_enable_latency_first:-false}"

CONFIG_FILE="${TRIM_PKGVAR}/easytier.conf"

if [ -f "${CONFIG_FILE}" ]; then
    echo "配置文件已存在，跳过创建: ${CONFIG_FILE}"
    exit 0
fi

cat > "${CONFIG_FILE}" << EOF
[network]
network_name = "${NETWORK_NAME}"
network_secret = "${NETWORK_SECRET}"
virtual_ip = "${VIRTUAL_IP}"
public_server = "${PUBLIC_SERVER}"
enable_encryption = "${ENABLE_ENCRYPTION}"
latency_first = "${LATENCY_FIRST}"
EOF

exit 0
